---
import type { Model } from './Models.astro';

interface Props {
    params: Model
}

const { params } = Astro.props;
---

<div>
    <a href=`${params?.public_url}`, target="_blank">
        <img src={params.preview_image} />
        <h2>
            {params.name}
        </h2>
    </a>
</div>

<style>
    a {
        color: inherit;
        text-decoration: none;
    }
    div {
        height: 100%;
        width: 40%;
        margin: 2%;
        border: solid rgb(217, 219, 210);;
        border-radius: 20px;
        padding: 2%;
        display: flex;
        flex-direction: column;
    }
    div:hover {
        background-color: blueviolet;
        cursor: pointer;
    }
</style>